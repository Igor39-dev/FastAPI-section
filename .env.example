# Скопируйте в `.env` и заполните под свой сценарий.

# --- Redis в Docker (сервис `redis` в compose) ---
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL на вашем ПК (основной сценарий: только api + redis в Docker) ---
# Из контейнера хост доступен как host.docker.internal (Docker Desktop; на Linux см. extra_hosts в compose).
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

CACHE_TIMEZONE=Europe/Moscow

# --- Только если поднимаете Postgres контейнером: docker compose --profile bundled-postgres up ---
# Тогда в .env выставьте DB_HOST=db и те же имя БД/пользователь/пароль, что и ниже.
# POSTGRES_USER=spimex
# POSTGRES_PASSWORD=spimex
# POSTGRES_DB=spimex
